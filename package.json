{
  "name": "opencode-mcp-server",
  "version": "1.0.0",
  "description": "MCP Server adapter for OpenCode CLI - exposes OpenCode AI coding capabilities via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "opencode-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "opencode",
    "ai",
    "coding-assistant",
    "model-context-protocol"
  ],
  "author": "shichao.han",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
